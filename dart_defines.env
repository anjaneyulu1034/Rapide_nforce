# Release build commands for rapide_nforce
# Icons show as Chinese characters in release without --no-tree-shake-icons
# (Flutter icon font subsetting bug with this project's icon usage pattern)

# APK:
#   flutter build apk --no-tree-shake-icons
#
# App Bundle:
#   flutter build appbundle --no-tree-shake-icons
#
# Test release on device:
#   flutter run --release --no-tree-shake-icons
